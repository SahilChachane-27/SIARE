
{
  "entities": {
    "Journal": {
      "title": "Journal",
      "description": "A scholarly journal or proceedings series hosted on the platform.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the journal."
        },
        "description": {
          "type": "string",
          "description": "A brief overview or description of the journal's scope."
        },
        "issn": {
          "type": "string",
          "description": "The ISSN of the journal."
        },
        "domain": {
          "type": "string",
          "description": "The academic field or domain."
        },
        "indexing": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of indexing services."
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "The external URL for the journal."
        },
        "imageUrl": {
          "type": "string",
          "description": "The cover image URL."
        },
        "isFeatured": {
          "type": "boolean",
          "description": "Whether the journal is featured."
        }
      },
      "required": ["name", "issn", "domain", "link"]
    },
    "Member": {
      "title": "Member",
      "description": "An individual scholar or student member of SIARE.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "institution": { "type": "string" },
        "tier": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] },
        "joinedAt": { "type": "object" }
      },
      "required": ["name", "email", "tier"]
    },
    "PricingPlan": {
      "title": "Pricing Plan",
      "description": "A dynamic pricing plan for journal hosting.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "priceINR": { "type": "string" },
        "priceUSD": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "cta": { "type": "string" },
        "highlight": { "type": "boolean" },
        "tag": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "priceINR", "priceUSD", "features"]
    },
    "MembershipTier": {
      "title": "Membership Tier",
      "description": "A dynamic membership tier for scholars.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "priceINR": { "type": "string" },
        "priceUSD": { "type": "string" },
        "description": { "type": "string" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["name", "priceINR", "priceUSD", "benefits"]
    },
    "Conference": {
      "title": "Conference",
      "description": "An upcoming academic conference managed by SIARE.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "description": "e.g. Call for Papers Open, Registration Open" },
        "tracks": { "type": "string" },
        "highlights": { "type": "string" },
        "color": { "type": "string", "description": "Tailwind color class, e.g. bg-blue-500" },
        "order": { "type": "number" }
      },
      "required": ["title", "date", "location"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact or membership inquiry submitted by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "institution": { "type": "string" },
        "purpose": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "contacted", "archived"] },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "email", "phone", "purpose", "message"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/journals/{journalId}": {
      "schema": { "$ref": "#/backend/entities/Journal" },
      "description": "Collection of university journals/proceedings."
    },
    "/members/{memberId}": {
      "schema": { "$ref": "#/backend/entities/Member" },
      "description": "Collection of society members."
    },
    "/pricingPlans/{planId}": {
      "schema": { "$ref": "#/backend/entities/PricingPlan" },
      "description": "Collection of dynamic pricing plans."
    },
    "/membershipTiers/{tierId}": {
      "schema": { "$ref": "#/backend/entities/MembershipTier" },
      "description": "Collection of dynamic membership tiers."
    },
    "/conferences/{conferenceId}": {
      "schema": { "$ref": "#/backend/entities/Conference" },
      "description": "Collection of upcoming conferences and events."
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/backend/entities/Inquiry" },
      "description": "Collection of user inquiries and membership applications."
    }
  }
}
